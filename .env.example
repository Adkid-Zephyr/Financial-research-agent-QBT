TZ=Asia/Shanghai

POSTGRES_DB=futures_research
POSTGRES_USER=futures
POSTGRES_PASSWORD=futures_dev_password

DATABASE_URL=postgresql+psycopg://futures:futures_dev_password@postgres:5432/futures_research

CTP_SNAPSHOT_BASE_URL=https://pc-api.qibaotu.com
CTP_SNAPSHOT_AUTH_KEY=
CTP_SNAPSHOT_SKIP_CRYPTO=true
CTP_SNAPSHOT_SKIP_CHECK=true
CTP_SNAPSHOT_VERIFY_SSL=true
CTP_REQUEST_TIMEOUT_SECONDS=8

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
LLM_MODEL=kimi-k2.5
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
ANALYSIS_RENDER_MODE=hybrid
REPORT_RENDER_MODE=hybrid

ENABLE_ANTHROPIC_WEB_SEARCH=false
ENABLE_REAL_DATA_SOURCES=true
ENABLE_YAHOO_MARKET_SOURCE=true
YAHOO_MARKET_MAX_STALE_DAYS=5
YAHOO_MARKET_LOOKBACK_DAYS=10
ENABLE_AKSHARE_COMMODITY_SOURCE=true
AKSHARE_COMMODITY_MAX_STALE_DAYS=10
DEFAULT_REPORT_WORD_TARGET=1800
MIN_PASS_SCORE=75
MAX_REVIEW_ROUNDS=2

NGINX_PORT=8080
